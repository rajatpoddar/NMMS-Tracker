# ─── Copy this to .env and fill in values ────────────────────────────────────
# cp .env.example .env

# PostgreSQL connection string
# In Docker: postgres service name is used as host
DATABASE_URL="postgresql://nmms:YOUR_PASSWORD_HERE@postgres:5432/nmms_db"

# Directory where NMMS photos are downloaded and served from
# In Docker: /app/data/photos (mounted volume)
# In dev: ./public/photos
PHOTOS_DIR="/app/data/photos"

# Strong password for PostgreSQL (used in docker-compose)
POSTGRES_PASSWORD="NmmsSecure@2026"

# Timezone
TZ="Asia/Kolkata"
